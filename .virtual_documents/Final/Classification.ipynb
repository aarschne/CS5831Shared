    ("lda", LinearDiscriminantAnalysis(solver="lsqr", shrinkage="auto"))
])


pipe.fit(X_train, y_train)
y_pred = pipe.predict(X_test)


recall = recall_score(y_test, y_pred, average="binary")
print("Recall:", recall)


result = permutation_importance(
    pipe, X_test, y_test,
