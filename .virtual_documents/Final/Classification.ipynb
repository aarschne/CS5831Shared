)

importance = pd.DataFrame({
    "feature": X_test.columns,
    "importance": result.importances_mean
}).sort_values(by="importance", ascending=False)

print(importance.head(10))


num_pipeline = Pipeline([
    ("imputer", KNNImputer(n_neighbors=5))
])

cat_pipeline = Pipeline([
    ("imputer", SimpleImputer(strategy="most_frequent")),
    ("onehot", OneHotEncoder(handle_unknown="ignore"))
])

preprocess = ColumnTransformer([
    ("num", num_pipeline, num_cols),
    ("cat", cat_pipeline, cat_cols)
])

pipe = Pipeline([
    ("preprocess", preprocess),
    ("lgbm", LGBMClassifier(
        n_estimators=200,
        learning_rate=0.05,
        num_leaves=31,
        subsample=0.8,
        colsample_bytree=0.8,
        random_state=5831
    ))
])


pipe.fit(X_train, y_train)
y_pred = pipe.predict(X_test)


recall = recall_score(y_test, y_pred, average="binary")
print("Recall:", recall)


with warnings.catch_warnings():
    warnings.simplefilter("ignore")

    result = permutation_importance(
    pipe, X_test, y_test,
    n_repeats=10,
    random_state=5831,
    n_jobs=-1
    )

    importance = pd.DataFrame({
    "feature": X_test.columns,
    "importance": result.importances_mean
    }).sort_values(by="importance", ascending=False)

    print(importance.head(10)) 


# preprocessing
num_pipeline = Pipeline([
    ("imputer", KNNImputer(n_neighbors=5)),
    ("scaler", StandardScaler())
])

cat_pipeline = Pipeline([
    ("imputer", SimpleImputer(strategy="most_frequent")),
    ("onehot", OneHotEncoder(handle_unknown="ignore", sparse_output=False))
])

preprocess = ColumnTransformer([
    ("num", num_pipeline, num_cols),
    ("cat", cat_pipeline, cat_cols)
])

# transform
X_train_trans = preprocess.fit_transform(X_train)
X_test_trans = preprocess.transform(X_test)

# model
tabnet = TabNetClassifier(seed=5831)

tabnet.fit(
    X_train_trans, y_train.to_numpy(),
    eval_set=[(X_test_trans, y_test.to_numpy())],
    max_epochs=100,
    patience=10,
    batch_size=1024,
    virtual_batch_size=128
)

# predictions
y_pred = tabnet.predict(X_test_trans)

# metrics
print("Recall:", recall_score(y_test, y_pred, average="weighted"))
print(classification_report(y_test, y_pred))

# feature importance
importance = pd.DataFrame({
    "feature": preprocess.get_feature_names_out(),
    "importance": tabnet.feature_importances_
}).sort_values("importance", ascending=False)

print(importance.head(20))



