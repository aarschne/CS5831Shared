def data_preprocessing(df):
    scaler = StandardScaler()
    df_scaled = scaler.fit_transform(df.iloc[:, 8:])
    pca = PCA()
    df_tr = pca.fit_transform(df_scaled)
    return df_tr

transformations = []

for i in range (97, 116):
    file = pd.read_csv(f"congress/H{i}_votes.csv")
    df_preprocessed = data_preprocessing(file)

    temp = pd.DataFrame({
        "PC1": df_preprocessed[:, 0],
        "PC2":  df_preprocessed[:, 1],
        "party_code": file["PartyCode"],
        "congress": i
    })
    transformations.append(temp)

transformations = pd.concat(transformations, ignore_index=True)

# Create small multiples plot
g = sns.FacetGrid(transformations, col="congress", col_wrap=3, height=3);
g.map_dataframe(sns.scatterplot, x="PC1", y="PC2", hue="party_code", palette=["red", "blue", "green"], s=10);
g.add_legend();
g.set_axis_labels("Principle Component 1", "Principle Component 2");








