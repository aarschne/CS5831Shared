# Read in Pokemon data

pok = pd.read_csv("pokemon.csv")

pok.head()


grader.check("q2a")





# Create violinplot
# stats to be analyzed
stats = ["hp", "attack", "defense", "sp_attack", "sp_defense", "speed"]

# reshape so they are in long format
pok_long = pok[stats].melt(
    var_name="stats",
    value_name="value"
)

# make violinplot
plt.figure(figsize=(10,6))
sns.violinplot(data=pok_long, x="stats", y="value", inner="quartile")

plt.title("Distribution of Pokémon Stats")
plt.xlabel("Stats")
plt.ylabel("Stat Value")

plt.show()







# Scale the data 

scaler = StandardScaler()

pokScaled = scaler.fit_transform(pok[stats])



grader.check("q2c")





# Run PCA on the scaled data 

pokPCA = PCA()
pokTr = pokPCA.fit_transform(pokScaled)



grader.check("q2d")





# Plot the transformed data  
plt.figure(figsize=(6,6))
plt.scatter(pokTr[:, 0], pokTr[:, 1])
plt.xlabel("PC1")
plt.ylabel("PC2")
plt.title("PCA Space of Pokemon Stats")
plt.show()






# Plot variance explained by each component   

var_explained = pokPCA.explained_variance_ratio_
pcs = np.arange(1, len(var_explained) + 1)

plt.figure(figsize=(6,4))
plt.plot(pcs, var_explained, marker="o")
plt.xlabel("PC")
plt.ylabel("Proportion of Explained Variance")
plt.title("Variance Explained by Principal Components")
plt.show()






# Plot the cumulative variance explained.   

cum_variance = np.cumsum(pokPCA.explained_variance_ratio_)
pcs = np.arange(1, len(cum_variance) + 1)

plt.figure(figsize=(6,4))
plt.plot(pcs, cum_variance, marker="o")
plt.xlabel("PC")
plt.ylabel("Cumulative Proportion of Explained Variance")
plt.title("Cumulative Variance Explained by PC Number")
plt.ylim(0, 1.05)
plt.show()






# Create plot   

# find all the types
types = pok["type1"].unique()

plt.figure(figsize=(7,6))

# iterate over types and make the overlapping scatterplots
for typ in types:
    idx = pok["type1"] == typ
    plt.scatter(
        pokTr[idx, 0],
        pokTr[idx, 1],
        label=typ,
        alpha=0.7
    )

plt.xlabel("PC1")
plt.ylabel("PC2")
plt.title("Pokemon PCA by Type1")

# make legend
plt.legend(bbox_to_anchor=(1.05, 1), loc="upper left")

plt.tight_layout()
plt.show()









